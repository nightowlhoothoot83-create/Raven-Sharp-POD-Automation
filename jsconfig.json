# --- Image optimise --------------------------------------------------------
class TestOptimise:
    def test_optimise_png(self, premium_client):
        b64 = _real_artwork_b64()
        r = premium_client.post(f"{BASE_URL}/api/image/optimise",
                                json={"image_base64": b64, "width": 1024, "height": 1024,
                                      "sharpen": 3, "saturation": 5, "output_format": "png"},
                                timeout=60)
        assert r.status_code == 200, r.text
        data = r.json()
        assert data["mime_type"] == "image/png"
        assert data["width"] > 0 and data["height"] > 0
        # Decode to verify validity
        out = base64.b64decode(data["image_base64"])
        Image.open(io.BytesIO(out)).verify()

    def test_optimise_jpeg(self, premium_client):
        b64 = _real_artwork_b64()
        r = premium_client.post(f"{BASE_URL}/api/image/optimise",
                                json={"image_base64": b64, "width": 800, "height": 800,
                                      "sharpen": 2, "saturation": 3, "output_format": "jpeg"},
                                timeout=60)
        assert r.status_code == 200, r.text
        data = r.json()
        assert data["mime_type"] == "image/jpeg"

    def test_optimise_invalid(self, premium_client):
        r = premium_client.post(f"{BASE_URL}/api/image/optimise",
                                json={"image_base64": "not_base64_at_all"})
        assert r.status_code == 400


# --- POD analyze (Claude Vision) -------------------------------------------
class TestPodAnalyze:
    def test_analyze_artwork(self, premium_client, premium_user):
        b64 = _real_artwork_b64()
        r = premium_client.post(f"{BASE_URL}/api/pod/analyze",
                                json={"image_base64": b64, "mime_type": "image/png", "image_name": "raven",
                                      "primary_market": "global", "price_tier": "mid",
                                      "shop_name": "Test Shop", "platform": "etsy"},
                                timeout=120)
        assert r.status_code == 200, r.text
        data = r.json()
        assert "project_id" in data
        analysis = data["analysis"]
        assert "artworkDescription" in analysis and len(analysis["artworkDescription"]) > 0
        assert "recommendedProducts" in analysis and len(analysis["recommendedProducts"]) >= 3
        assert "seoTitle" in analysis
        assert "keywords" in analysis and len(analysis["keywords"]) >= 5
        # verify usage incremented
        u = premium_client.get(f"{BASE_URL}/api/usage/current").json()
        assert u["usage"]["pod_analyses"]["used"] >= 1


# --- POD generate image (Gemini) -------------------------------------------
class TestImageGen:
    def test_generate(self, premium_client):
        r = premium_client.post(f"{BASE_URL}/api/pod/generate-image",
                                json={"prompt": "A simple geometric mountain logo, minimal, vector style",
                                      "style": "minimalist"},
                                timeout=120)
        assert r.status_code == 200, r.text
        data = r.json()
        assert "image_base64" in data and len(data["image_base64"]) > 100
