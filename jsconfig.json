"""End-to-end backend tests for Raven Sharp Studio."""
import os
import io
import base64
import time
import pytest
import requests
from PIL import Image, ImageDraw
from pymongo import MongoClient

BASE_URL = os.environ.get('REACT_APP_BACKEND_URL', 'https://integration-demo-1.preview.emergentagent.com').rstrip('/')
MONGO_URL = os.environ.get('MONGO_URL', 'mongodb://localhost:27017')
DB_NAME = os.environ.get('DB_NAME', 'test_database')


def _real_artwork_b64():
    """Generate a meaningful image (not blank): a colourful stylised raven illustration."""
    img = Image.new('RGB', (512, 512), (15, 15, 30))  # dark background
    d = ImageDraw.Draw(img)
    # Moon
    d.ellipse((340, 60, 460, 180), fill=(240, 235, 200))
    # Raven body
    d.polygon([(150, 200), (260, 160), (370, 220), (340, 340), (180, 360)], fill=(20, 20, 25))
    # Wing
    d.polygon([(260, 200), (340, 180), (390, 240), (310, 280)], fill=(45, 45, 60))
    # Beak
    d.polygon([(150, 215), (110, 225), (155, 240)], fill=(180, 140, 30))
    # Eye
    d.ellipse((175, 210, 195, 230), fill=(220, 180, 50))
    d.ellipse((182, 217, 190, 225), fill=(0, 0, 0))
    # Branch
    d.line((50, 380, 460, 410), fill=(80, 60, 40), width=8)
    # Stars
    for x, y in [(60, 90), (120, 50), (220, 110), (300, 80), (430, 230), (90, 200), (480, 350)]:
        d.ellipse((x - 2, y - 2, x + 2, y + 2), fill=(255, 255, 220))
    buf = io.BytesIO()
    img.save(buf, format='PNG')
    return base64.b64encode(buf.getvalue()).decode('utf-8')


# --- Health & root ---------------------------------------------------------
class TestHealth:
    def test_root(self, anon_client):
        r = anon_client.get(f"{BASE_URL}/api/")
        assert r.status_code == 200
        data = r.json()
        assert data["service"] == "Raven Sharp Studio API"


# --- Auth ------------------------------------------------------------------
class TestAuth:
    def test_login_session_invalid(self, anon_client):
        r = anon_client.post(f"{BASE_URL}/api/auth/login-session", json={"session_id": "INVALID_FAKE_SESSION"})
        assert r.status_code == 401

    def test_me_no_token(self, anon_client):
        r = anon_client.get(f"{BASE_URL}/api/auth/me")
        assert r.status_code == 401

    def test_me_with_token(self, premium_client, premium_user):
        r = premium_client.get(f"{BASE_URL}/api/auth/me")
        assert r.status_code == 200
        data = r.json()
        assert data["user_id"] == premium_user["user_id"]
        assert data["tier"] == "premium"

    def test_logout_idempotent(self, anon_client):
        r = anon_client.post(f"{BASE_URL}/api/auth/logout")
        assert r.status_code == 200
        assert r.json().get("ok") is True


# --- Auth gating -----------------------------------------------------------
class TestAuthGating:
    @pytest.mark.parametrize("path,method,body", [
        ("/api/usage/current", "get", None),
        ("/api/projects", "get", None),
        ("/api/gelato/stores", "get", None),
        ("/api/account/gelato-key", "post", {"api_key": "x"}),
        ("/api/pod/analyze", "post", {"image_base64": "x"}),
        ("/api/pod/generate-image", "post", {"prompt": "x"}),
        ("/api/image/optimise", "post", {"image_base64": "x"}),
        ("/api/content/generate", "post", {"content_type": "blog_post", "topic": "x"}),
        ("/api/billing/checkout", "post", {"tier": "pro", "origin_url": "https://x"}),
    ])
    def test_protected(self, anon_client, path, method, body):
        fn = getattr(anon_client, method)
        r = fn(f"{BASE_URL}{path}", json=body) if body is not None else fn(f"{BASE_URL}{path}")
        assert r.status_code == 401, f"{path} should require auth, got {r.status_code}"


# --- Usage -----------------------------------------------------------------
class TestUsage:
    def test_usage_current(self, premium_client):
        r = premium_client.get(f"{BASE_URL}/api/usage/current")
        assert r.status_code == 200
        data = r.json()
        assert data["tier"] == "premium"
        for k in ["pod_analyses", "image_generations", "image_optimisations", "content_generations"]:
            assert k in data["usage"]
            assert "used" in data["usage"][k]
            assert "limit" in data["usage"][k]


# --- Content generation (Claude) -------------------------------------------
class TestContent:
