        assert img.size[0] > 0


# --- Billing / Stripe ------------------------------------------------------
class TestBilling:
    def test_checkout_pro(self, premium_client):
        r = premium_client.post(f"{BASE_URL}/api/billing/checkout",
                                json={"tier": "pro", "origin_url": BASE_URL})
        assert r.status_code == 200, r.text
        data = r.json()
        assert "url" in data and "session_id" in data
        assert "stripe.com" in data["url"] or "checkout" in data["url"].lower()

    def test_checkout_premium(self, premium_client):
        r = premium_client.post(f"{BASE_URL}/api/billing/checkout",
                                json={"tier": "premium", "origin_url": BASE_URL})
        assert r.status_code == 200, r.text
        assert "url" in r.json()

    def test_checkout_free_rejected(self, premium_client):
        r = premium_client.post(f"{BASE_URL}/api/billing/checkout",
                                json={"tier": "free", "origin_url": BASE_URL})
        assert r.status_code == 400

    def test_checkout_invalid_tier(self, premium_client):
        r = premium_client.post(f"{BASE_URL}/api/billing/checkout",
                                json={"tier": "diamond", "origin_url": BASE_URL})
        assert r.status_code == 400

    def test_status_unknown_session(self, premium_client):
        r = premium_client.get(f"{BASE_URL}/api/billing/status/cs_test_DOES_NOT_EXIST")
        # Stripe will 502 (bad request to stripe) or 404 (transaction not found)
        assert r.status_code in (404, 502)


# --- Account / Gelato ------------------------------------------------------
class TestAccount:
    def test_save_gelato_key(self, premium_client, premium_user):
        r = premium_client.post(f"{BASE_URL}/api/account/gelato-key",
                                json={"api_key": "TEST_GELATO_KEY_12345"})
        assert r.status_code == 200
        # Verify persistence
        mc = MongoClient(MONGO_URL); db = mc[DB_NAME]
        u = db.users.find_one({"user_id": premium_user["user_id"]})
        assert u["gelato_api_key"] == "TEST_GELATO_KEY_12345"
        mc.close()

    def test_gelato_stores_no_key(self, free_client):
        r = free_client.get(f"{BASE_URL}/api/gelato/stores")
        assert r.status_code == 400


# --- Tier enforcement (402) ------------------------------------------------
class TestTierLimit:
    def test_402_when_limit_reached(self, free_client, free_user):
        # Free tier image_generations limit = 2. Set used=2 directly.
        mc = MongoClient(MONGO_URL); db = mc[DB_NAME]
        from datetime import datetime as dt
        now = dt.utcnow()
        mk = f"{now.year:04d}-{now.month:02d}"
        db.usage.update_one(
            {"user_id": free_user["user_id"], "month": mk},
            {"$set": {"image_generations": 99, "content_generations": 99}},
            upsert=True,
        )
        mc.close()
        r = free_client.post(f"{BASE_URL}/api/content/generate",
                             json={"content_type": "blog_post", "topic": "test"},
                             timeout=30)
        assert r.status_code == 402
