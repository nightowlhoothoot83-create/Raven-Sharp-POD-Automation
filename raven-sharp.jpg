import React, { useEffect, useState } from "react";
import { Link } from "react-router-dom";
import api from "../lib/api";
import { useAuth } from "../context/AuthContext";
import { Sparkles, Wand2, Image as ImageIcon, FileText, ArrowRight, Zap } from "lucide-react";

export default function Dashboard() {
  const { user } = useAuth();
  const [usage, setUsage] = useState(null);

  useEffect(() => {
    api.get("/usage/current").then(({ data }) => setUsage(data)).catch(() => {});
  }, []);

  const tools = [
    { to: "/pod-suite", icon: Sparkles, title: "POD Suite", desc: "Drop artwork → product portfolio + SEO + Gelato CSV.", testid: "card-pod" },
    { to: "/image-gen", icon: Wand2, title: "AI Image Gen", desc: "Text → print-ready artwork via Gemini Nano Banana.", testid: "card-imgen" },
    { to: "/optimiser", icon: ImageIcon, title: "Image Optimiser", desc: "Resize, sharpen, boost colour, convert format.", testid: "card-optimiser" },
    { to: "/content", icon: FileText, title: "Content Engine", desc: "Descriptions, blogs, SEO copy, social captions.", testid: "card-content" },
  ];

  return (
    <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <div className="fade-up mb-10">
        <span className="text-xs font-mono uppercase tracking-[0.25em] text-[var(--gold)]">Studio</span>
        <h1 className="font-display text-4xl sm:text-5xl font-black tracking-tighter mt-2">
          Welcome back, <span className="text-[var(--raven-glow)]">{user?.name?.split(" ")[0] || "creator"}</span>.
        </h1>
        <p className="text-[var(--muted)] mt-2">Pick a tool. Build something sellable.</p>
      </div>

      {/* Usage panel */}
      <div className="glass rounded-2xl p-6 mb-10" data-testid="dashboard-usage-panel">
        <div className="flex items-center justify-between mb-4">
          <div className="flex items-center gap-2">
            <Zap className="w-4 h-4 text-[var(--gold)]" />
            <span className="font-display text-lg font-semibold tracking-tight">This month</span>
          </div>
          <Link to="/pricing" className="text-xs font-mono uppercase tracking-widest text-[var(--raven-glow)] hover:text-white">
            Upgrade →
          </Link>
        </div>
        <div className="grid grid-cols-2 md:grid-cols-4 gap-4">
          {usage ? (
            Object.entries(usage.usage).map(([k, v]) => (
              <UsageBar key={k} label={labelFor(k)} used={v.used} limit={v.limit} testid={`usage-${k}`} />
            ))
          ) : (
            <div className="col-span-4 text-sm text-[var(--muted)]">Loading usage...</div>
          )}
        </div>
      </div>

      {/* Tool grid */}
      <div className="grid grid-cols-1 sm:grid-cols-2 gap-6">
        {tools.map((t) => (
          <Link
            key={t.to}
            to={t.to}
            data-testid={t.testid}
            className="group glass rounded-2xl p-8 card-hover flex items-start justify-between gap-4"
          >
            <div>
              <div className="w-12 h-12 rounded-xl bg-[var(--raven)]/15 border border-[var(--raven)]/30 flex items-center justify-center mb-4 group-hover:bg-[var(--raven)]/25 transition-colors">
                <t.icon className="w-5 h-5 text-[var(--raven-glow)]" />
              </div>
              <h3 className="font-display text-2xl font-bold tracking-tight">{t.title}</h3>
              <p className="text-sm text-[var(--muted)] mt-2 max-w-sm">{t.desc}</p>
            </div>
            <ArrowRight className="w-5 h-5 text-[var(--muted)] group-hover:text-[var(--raven-glow)] group-hover:translate-x-1 transition-all mt-1" />
          </Link>
        ))}
      </div>
    </div>
  );
}

function labelFor(k) {
  return ({
    pod_analyses: "POD Analyses",
    image_generations: "Image Gen",
    image_optimisations: "Optimisations",
    content_generations: "Content",
  })[k] || k;
}

function UsageBar({ label, used, limit, testid }) {
  const pct = limit > 0 ? Math.min(100, (used / limit) * 100) : 0;
  return (
    <div data-testid={testid}>
      <div className="flex items-baseline justify-between mb-1.5">
        <span className="text-xs font-mono uppercase tracking-widest text-[var(--muted)]">{label}</span>
        <span className="font-mono text-xs text-white">{used}<span className="text-[var(--subtle)]">/{limit}</span></span>
      </div>
      <div className="rs-progress-track">
        <div className="rs-progress-fill" style={{ width: `${pct}%` }} />
      </div>
    </div>
  );
}
