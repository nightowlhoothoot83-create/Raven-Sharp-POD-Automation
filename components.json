import React, { useRef, useState } from "react";
import { toast } from "sonner";
import api from "../lib/api";
import { Button } from "@/components/ui/button";
import { Label } from "@/components/ui/label";
import { Slider } from "@/components/ui/slider";
import { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from "@/components/ui/select";
import { Input } from "@/components/ui/input";
import { Upload, Download, RefreshCw } from "lucide-react";
import { fileToBase64, downloadBase64 } from "../lib/file-utils";

const PRESETS = [
  { value: "pod", label: "POD Standard 4500×4500", w: 4500, h: 4500 },
  { value: "etsy", label: "Etsy Digital 3000×3000", w: 3000, h: 3000 },
  { value: "large", label: "Large Print 4800×4800", w: 4800, h: 4800 },
  { value: "ig", label: "Instagram Square 2048×2048", w: 2048, h: 2048 },
  { value: "custom", label: "Custom", w: 4500, h: 4500 },
];

export default function Optimiser() {
  const [img, setImg] = useState(null);
  const [result, setResult] = useState(null);
  const [loading, setLoading] = useState(false);
  const [preset, setPreset] = useState("pod");
  const [custom, setCustom] = useState({ w: 4500, h: 4500 });
  const [format, setFormat] = useState("png");
  const [sharpen, setSharpen] = useState([3]);
  const [saturation, setSaturation] = useState([5]);
  const fileRef = useRef(null);

  const onFile = async (file) => {
    if (!file) return;
    const b64 = await fileToBase64(file);
    setImg({ name: file.name, mime: file.type, base64: b64.split(",")[1], src: b64 });
    setResult(null);
  };

  const run = async () => {
    if (!img) return toast.error("Upload an image first");
    setLoading(true);
    const p = PRESETS.find((x) => x.value === preset);
    const w = preset === "custom" ? custom.w : p.w;
    const h = preset === "custom" ? custom.h : p.h;
    try {
      const { data } = await api.post("/image/optimise", {
        image_base64: img.base64,
        mime_type: img.mime,
        width: w,
        height: h,
        sharpen: sharpen[0],
        saturation: saturation[0],
        output_format: format,
      });
      setResult(data);
      toast.success(`Optimised to ${data.width}×${data.height}`);
    } catch (e) {
      toast.error(e.response?.data?.detail || e.message);
    } finally {
      setLoading(false);
    }
  };

  return (
    <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
      <div className="mb-8">
        <span className="text-xs font-mono uppercase tracking-[0.25em] text-[var(--gold)]">Image Optimiser</span>
        <h1 className="font-display text-4xl sm:text-5xl font-black tracking-tighter mt-2">
          Print-grade prep, one click.
        </h1>
        <p className="text-[var(--muted)] mt-2">Resize, sharpen, boost colour, convert format.</p>
      </div>

      <div className="grid lg:grid-cols-3 gap-6">
        <div className="lg:col-span-1 glass rounded-2xl p-6 space-y-5" data-testid="optimiser-panel">
          <div
            onClick={() => fileRef.current?.click()}
            onDragOver={(e) => e.preventDefault()}
            onDrop={(e) => { e.preventDefault(); onFile(e.dataTransfer.files[0]); }}
            className="dropzone rounded-xl p-6 text-center cursor-pointer"
            data-testid="optimiser-dropzone"
          >
            {img ? (
              <img src={img.src} alt="original" className="max-h-40 mx-auto rounded-lg" />
            ) : (
              <>
                <Upload className="w-8 h-8 mx-auto mb-2 text-[var(--raven-glow)]" />
                <div className="text-sm">Drop an image or click</div>
              </>
            )}
            <input ref={fileRef} type="file" accept="image/*" className="hidden" onChange={(e) => onFile(e.target.files[0])} data-testid="optimiser-file-input" />
          </div>

          <div>
            <Label className="text-xs font-mono uppercase tracking-widest text-[var(--muted)]">Output Size</Label>
            <Select value={preset} onValueChange={setPreset}>
              <SelectTrigger className="mt-1.5" data-testid="optimiser-preset"><SelectValue /></SelectTrigger>
              <SelectContent>{PRESETS.map((p) => <SelectItem key={p.value} value={p.value}>{p.label}</SelectItem>)}</SelectContent>
            </Select>
          </div>

          {preset === "custom" && (
            <div className="grid grid-cols-2 gap-2">
              <Input type="number" value={custom.w} onChange={(e) => setCustom({ ...custom, w: +e.target.value })} placeholder="Width" data-testid="optimiser-custom-w" />
              <Input type="number" value={custom.h} onChange={(e) => setCustom({ ...custom, h: +e.target.value })} placeholder="Height" data-testid="optimiser-custom-h" />
            </div>
          )}

          <div>
            <Label className="text-xs font-mono uppercase tracking-widest text-[var(--muted)]">Format</Label>
            <Select value={format} onValueChange={setFormat}>
              <SelectTrigger className="mt-1.5" data-testid="optimiser-format"><SelectValue /></SelectTrigger>
              <SelectContent>
                <SelectItem value="png">PNG (best quality)</SelectItem>
                <SelectItem value="jpeg">JPEG (smaller file)</SelectItem>
              </SelectContent>
            </Select>
          </div>

          <div>
            <div className="flex justify-between mb-1.5">
              <Label className="text-xs font-mono uppercase tracking-widest text-[var(--muted)]">Sharpen</Label>
              <span className="text-xs font-mono text-white">{sharpen[0]}</span>
            </div>
            <Slider value={sharpen} onValueChange={setSharpen} min={0} max={10} step={1} data-testid="optimiser-sharpen" />
          </div>
          <div>
            <div className="flex justify-between mb-1.5">
              <Label className="text-xs font-mono uppercase tracking-widest text-[var(--muted)]">Enhance Colours</Label>
              <span className="text-xs font-mono text-white">{saturation[0]}</span>
            </div>
            <Slider value={saturation} onValueChange={setSaturation} min={0} max={20} step={1} data-testid="optimiser-saturation" />
          </div>

          <Button
            onClick={run}
            disabled={loading || !img}
            className="w-full h-11 bg-[var(--raven)] hover:bg-[var(--raven-glow)] text-white"
            data-testid="optimiser-run-btn"
          >
            {loading ? (<><RefreshCw className="w-4 h-4 mr-2 animate-spin" /> Processing...</>) : "Optimise"}
          </Button>
        </div>

        <div className="lg:col-span-2 glass rounded-2xl p-6 min-h-[500px] flex items-center justify-center" data-testid="optimiser-output">
          {result ? (
            <div className="w-full space-y-4">
              <img src={`data:${result.mime_type};base64,${result.image_base64}`} alt="optimised" className="w-full rounded-xl border border-white/10" />
              <div className="flex items-center justify-between flex-wrap gap-3">
                <div className="text-xs font-mono text-[var(--muted)] uppercase tracking-widest">
                  {result.width}×{result.height} · {(result.size_bytes / 1024).toFixed(1)} KB · {result.mime_type}
                </div>
                <Button
                  onClick={() => downloadBase64(result.image_base64, `optimised-${Date.now()}.${format}`, result.mime_type)}
                  className="bg-[var(--raven)] hover:bg-[var(--raven-glow)] text-white"
                  data-testid="optimiser-download"
                >
                  <Download className="w-4 h-4 mr-2" /> Download
                </Button>
              </div>
            </div>
          ) : (
            <div className="text-sm text-[var(--muted)]">Your optimised image will appear here</div>
          )}
        </div>
      </div>
    </div>
  );
}
